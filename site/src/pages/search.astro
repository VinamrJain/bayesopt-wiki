---
// Full-text search over all notes, powered by Pagefind.
//
// The Pagefind index is generated by the `build` script (astro build && pagefind --site dist), so
// search works in a production build and in `pixi run preview` — NOT in `pixi run dev` (no index is
// built in dev; the widget will report it can't load). bundlePath is base-aware so it resolves under
// the GitHub Pages project path (/bayesopt-wiki/pagefind/).
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Search · BO wiki" wide>
  <section class="search-page">
    <h1>Search</h1>
    <p class="section-sub">Full-text search across every note.</p>
    <div id="search"></div>
  </section>
</BaseLayout>

<script>
  import { PagefindUI } from '@pagefind/default-ui';
  import '@pagefind/default-ui/css/ui.css';

  new PagefindUI({
    element: '#search',
    showSubResults: true,
    showImages: false,
    bundlePath: import.meta.env.BASE_URL + 'pagefind/',
  });
</script>
